{
  "$schema": "https://railway.app",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "dotnet publish rec-be.csproj -c Release -o out"
  },
  "deploy": {
    "startCommand": "dotnet out/rec-be.dll"
  },
  "phases": {
    "setup": {
      "nixPkgs": [
        "dotnet-sdk_10"
      ]
    }
  }
}
